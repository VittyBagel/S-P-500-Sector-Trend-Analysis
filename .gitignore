# ========================================
# Data directory
# ========================================
# Ignore everything inside data/ by default
data/**

# Keep the folder structure
!data/raw/
!data/processed/
!data/raw/.gitkeep
!data/processed/.gitkeep

# Ignore large CSV files (GitHub limit is 100MB)
data/raw/*.csv
data/processed/*.csv

# ========================================
# Python
# ========================================
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/

# Virtual environments
.venv/
venv/
env/
ENV/

# ========================================
# OS & temporary files
# ========================================
.DS_Store
*.log
*.tmp
*.temp